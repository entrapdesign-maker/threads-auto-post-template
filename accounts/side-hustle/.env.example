# AI×副業・自動化 実演アカウント — 環境変数テンプレート
# このファイルを .env にコピーして実際の値を入力してください

# Anthropic API キー (共通)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Threads API — 新アカウント用のトークン
THREADS_USER_ID=your_new_threads_user_id
THREADS_ACCESS_TOKEN=your_new_threads_long_lived_token

# アカウント識別子 (変更不要)
ACCOUNT=side-hustle

# 使用するClaudeモデル (任意)
CLAUDE_MODEL=claude-sonnet-4-6
