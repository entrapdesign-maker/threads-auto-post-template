# AI×副業・自動化 実演アカウント — 環境変数テンプレート
# このファイルを .env にコピーして実際の値を入力してください

# Anthropic API キー (共通)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Threads API — 新アカウント用のトークン
THREADS_USER_ID=your_new_threads_user_id
THREADS_ACCESS_TOKEN=your_new_threads_long_lived_token

# アカウント識別子 (変更不要)
ACCOUNT=side-hustle

# 安全ガード: このトークンが属するべきThreadsユーザー名。投稿前に照合し、
# 不一致なら投稿を中止する(ドラフト取り違え事故の防止)。
EXPECTED_USERNAME=ai_lab_6960

# 使用するClaudeモデル (任意)
CLAUDE_MODEL=claude-sonnet-4-6
